# PATHS
export PATH="$PATH:$HOME/bin"
export CONFIG="$HOME/.config"

# Ansible
export ANSIBLE_CONFIG="$CONFIG/ansible"

# Terminal
export TERMINAL='xterm-kitty'
export TERM='xterm-kitty'

# Editor
export EDITOR='vim'
export SUDO_EDITOR='vim'

# Vim
export VIMRC="$HOME/.vim/"

# ZSH - Already Initialized on ZSH startup
export ZSH="$CONFIG/zsh"
export HISTFILE="$CONFIG/zsh/zsh_history"

# Dotfiles
export DOTFILES="$HOME/src/ddt/dotfiles"

# XDG User Dirs
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_DOWNLOAD_DIR="$HOME/dl"
export XDG_DOCUMENTS_DIR="$HOME/doc"
export XDG_PICTURES_DIR="$HOME/img"
export XDG_DESKTOP_DIR="$HOME/"
export XDG_TEMPLATES_DIR="$HOME/"
export XDG_PUBLICSHARE_DIR="$HOME/"

# Xauthority
export XAUTHORITY="$CONFIG/xorg/xauthority"
